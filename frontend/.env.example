# Frontend Configuration
# Your Alchemy API Key for frontend RPC and account kit integrations
VITE_ALCHEMY_API_KEY=
# Your Alchemy Gas Manager Policy ID for client-side transaction sponsoring
VITE_ALCHEMY_POLICY_ID=

# RainbowKit / WalletConnect project ID
VITE_WALLETCONNECT_PROJECT_ID=
# Blockchain Chain ID (e.g., 84532 for Base Sepolia)
VITE_CHAIN_ID=84532

# Pimlico configuration
VITE_PIMLICO_API_KEY=
VITE_PIMLICO_SPONSORSHIP_POLICY_ID=

# Backend API Configuration
# Base endpoint of the Express backend API
VITE_API_BASE_URL=http://localhost:3000

NODE_ENV=development
