# ===========================================
# NEXUS SMART WALLET BACKEND CONFIGURATION
# ===========================================

# ALCHEMY CONFIGURATION
# Your Alchemy API Key for RPC and Smart Account integrations
ALCHEMY_API_KEY=
# Your Alchemy Gas Manager Policy ID (optional/required for sponsorship)
ALCHEMY_POLICY_ID=

# PIMLICO CONFIGURATION
# Your Pimlico API Key for bundler/paymaster or fee oracle services
PIMLICO_API_KEY=
# Your Pimlico Sponsorship Policy ID (optional)
PIMLICO_POLICY_ID=

# CENTRALIZED WALLET CONFIGURATION (Required)
# EOA master private key used for smart account deployments and transactions
# MUST be a 32-byte hex starting with 0x (do NOT use the default test key in production)
MASTER_WALLET_PRIVATE_KEY=
MASTER_WALLET_ENABLED=true

# DATABASE CONFIGURATION (MongoDB)
# MongoDB connection URI (e.g. mongodb://localhost:27017/nexus-wallet)
MONGODB_URI=
MONGODB_DB_NAME=nexus-wallet
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT=5000
MONGODB_SOCKET_TIMEOUT=45000

# SERVER CONFIGURATION
PORT=3000
NODE_ENV=development
# Comma-separated allowed origins (e.g. http://localhost:5173)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001,http://localhost:8080,http://127.0.0.1:8080

# LOGGING CONFIGURATION
LOG_LEVEL=INFO

# SECURITY CONFIGURATION
# Secret key used for signing authentication JWT tokens (must be at least 32 characters)
JWT_SECRET=
# Key used to protect the /api/metrics endpoint from unauthorized read access
METRICS_KEY=

# REDIS CONFIGURATION (Required for Pub/Sub & Rate Limiting)
REDIS_URI=redis://localhost:6379
REDIS_ENABLED=true
